ALLOWED_EVENT_TYPES=com.stripe.v1.checkout.session.completed,com.stripe.v1.checkout.session.async_payment_succeeded,com.stripe.v1.checkout.session.async_payment_failed,com.stripe.v1.customer.subscription.created,com.stripe.v1.customer.subscription.updated,com.stripe.v1.customer.subscription.deleted,com.stripe.v1.tax_rate.created,com.stripe.v1.tax_rate.updated,com.stripe.v1.invoice.paid,com.stripe.v1.invoice.payment_succeeded,com.stripe.v1.invoice.payment_failed
CREATE_CHECKOUT_SESSION_MIN_INSTANCES=1
CUSTOMERS_COLLECTION=customers
DELETE_STRIPE_CUSTOMERS=Auto delete
EVENTARC_CHANNEL=projects/${param:PROJECT_ID}/locations/us-central1/channels/firebase
firebaseextensions.v1beta.function/ingressSettings=ALLOW_ALL
firebaseextensions.v1beta.function/maxInstances=1
firebaseextensions.v1beta.function/memory=128
firebaseextensions.v1beta.function/minInstances=0
firebaseextensions.v1beta.function/timeoutSeconds=18
firebaseextensions.v1beta.function/vpcConnectorEgressSettings=PRIVATE_RANGES_ONLY
LOCATION=us-east4
PRODUCTS_COLLECTION=Basic, Pro, Enterprise
STRIPE_API_KEY=projects/37210264160/secrets/ext-firestore-stripe-payments-STRIPE_API_KEY/versions/1
STRIPE_CONFIG_COLLECTION=configuration
STRIPE_WEBHOOK_SECRET=projects/37210264160/secrets/ext-firestore-stripe-payments-STRIPE_WEBHOOK_SECRET/versions/1
SYNC_USERS_ON_CREATE=Sync